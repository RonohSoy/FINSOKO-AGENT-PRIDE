    {
      "parameters": {
        "jsCode": "\nconst d = $('Format \u2014 Guardian Prompt').first().json;\nconst text = $input.first().json.content.filter(b=>b.type==='text').map(b=>b.text).join('');\nconst match = text.replace(/```json|```/g,'').trim().match(/\\{[\\s\\S]*\\}/);\nif(!match) throw new Error('Guardian: no JSON in response');\nconst r = JSON.parse(match[0]);\nreturn [{json:{...d, guardianResult:r, decision:r.decision}}];\n"
      },
      "id": "f68edb74-c6ca-4ab7-9f96-e0124a357656",
      "name": "Parse \u2014 Guardian Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1820,
        200
      ]
    },
    {
      "parameters": {
        "mode": "expression",
        "output": "={{ $json.decision }}",
        "options": {}
      },
      "id": "4b8099e4-7831-4c0f-aa5d-265447ecf5d3",
      "name": "PRIDE \u2014 Decision Branch",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        2080,
        200
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\"status\":\"approved\",\"decision\":\"APPROVE\",\"score\":{{ $json.guardianResult.score }},\"member\":{{ JSON.stringify($json.name) }},\"loanAmount\":{{ $json.loanAmount }},\"memberMessage\":{{ JSON.stringify($json.guardianResult.memberMessage) }},\"killSwitch\":\"*#733#\",\"appealCode\":\"*#123#\",\"dataLocation\":\"AWS Africa Cape Town\"}",
        "options": {}
      },
      "id": "c4489dd4-0e3a-41d1-9b1f-039d82e8d748",
      "name": "Respond \u2014 Auto-Approved",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
