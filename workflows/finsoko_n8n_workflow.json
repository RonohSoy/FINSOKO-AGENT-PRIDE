    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\"status\":\"denied\",\"decision\":\"DENY\",\"score\":{{ $json.guardianResult.score }},\"member\":{{ JSON.stringify($json.name) }},\"memberMessage\":{{ JSON.stringify($json.guardianResult.memberMessage) }},\"riskFlags\":{{ JSON.stringify($json.guardianResult.riskFlags) }},\"appealRights\":{\"ussd\":\"*#123#\",\"responseTime\":\"48 hours\",\"branch\":\"nearest SACCO agent\"},\"dignityFilter\":\"applied\",\"killSwitch\":\"*#733#\"}",
        "options": {}
      },
      "id": "c79d8999-3f80-4937-8da2-497dfe8b0fb0",
      "name": "Respond \u2014 Denied + Dignity",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        2340,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst d = $input.first().json;\nconst gr = d.guardianResult;\nconst prompt = `You are the Hunter Agent for Ujima SACCO \u2014 Human-in-Loop Coordinator.\nCRITICAL: CANNOT approve or deny loans. Briefing ONLY. KILL SWITCH: *#799# (full system pause).\nAlert officer within 15 minutes. TRAIL: Officer availability(T), specialties(R), patterns(A).\n\nMember: ${d.name}, ${d.occupation} | Income: KES ${d.income} (${d.incomeType})\nHarvest: ${d.harvestMonths} | Children: ${d.children}\nLoan: KES ${d.loanAmount} for ${d.purpose}\nGuardian score: ${gr.score}/100 | Risk flags: ${(gr.riskFlags||[]).join(', ')||'none'}\nBreakdown: Income ${gr.scoreBreakdown?.incomeConsistency}/40, Harvest ${gr.scoreBreakdown?.harvestAlignment}/30, Community ${gr.scoreBreakdown?.communitySignals}/20\n\nMatch fictional officer with relevant expertise (agricultural, women vendors, boda boda, North Rift).\n\nRespond ONLY valid JSON:\n{\"officerMatch\":\"Officer [Name] \u2014 [5-word specialty]\",\"officerContact\":\"contact\",\"briefingSummary\":\"2-sentence summary\",\"keyPoints\":[\"point1\",\"point2\",\"point3\"],\"recommendation\":\"1-sentence suggestion\",\"crossSellOpportunity\":\"product\",\"urgencyLevel\":\"HIGH\",\"culturalContext\":\"1-2 sentences\",\"prideLoop\":{\"pausePointTriggered\":true,\"humanReviewRequired\":true,\"reviewDeadline\":\"48 hours\",\"elderCouncilAlert\":false}}`;\n\nreturn [{json:{...d, requestBody: JSON.stringify({model:\"claude-sonnet-4-20250514\",max_tokens:1000,messages:[{role:\"user\",content:prompt}]})}}];\n"
      },
