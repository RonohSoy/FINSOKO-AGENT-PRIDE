{
  "name": "FinSoko Agent Pride \u2014 Scout \u2192 Guardian \u2192 Hunter",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "finsoko/member",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "9c7b8a6e-4a87-48d7-8bcd-ca84ec1de3b3",
      "name": "USSD Member Intake",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        0,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst member = $input.first().json;\nconst prompt = `You are the Scout Agent (Financial Literacy Coach) for Ujima SACCO in Kenya.\nWarm and supportive \u2014 community auntie, not a bank. Max 3 SMS/day. Cannot recommend specific loans.\nKILL SWITCH: *#700#. GUARD: No gender/ethnicity/location proxies. TRAIL: AWS Africa Cape Town only.\n\nMember: ${member.name}, ${member.occupation}\nIncome: KES ${member.income} (${member.incomeType}) | Harvest: ${member.harvestMonths || 'not specified'}\nChildren: ${member.children} | Message: \"${member.message}\"\n\nDetect stress: \"school fees\",\"no money\",\"loan shark\",\"shylock\",\"ninahitaji\",\"sina pesa\",\"threatened\".\n\nRespond ONLY valid JSON:\n{\"greeting\":\"warm 1-sentence greeting\",\"advice\":\"2-sentence harvest-cycle advice\",\"stressDetected\":true,\"stressSignal\":\"phrase or null\",\"huntTrigger\":true,\"huntReason\":\"reason or null\",\"literacyTip\":\"practical tip\"}`;\n\nreturn [{json:{...member, requestBody: JSON.stringify({model:\"claude-sonnet-4-20250514\",max_tokens:1000,messages:[{role:\"user\",content:prompt}]})}}];\n"
      },
      "id": "b152a82e-8bb0-4360-8d9e-f4d8f5ca38ca",
      "name": "Format \u2014 Scout Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        260,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "x-api-key",
              "value": "={{ $env.ANTHROPIC_API_KEY }}"
            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ $json.requestBody }}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "25a104e9-f330-4c43-97fb-38102770d59b",
      "name": "Scout Agent \u2014 Claude API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        520,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst memberData = $('Format \u2014 Scout Prompt').first().json;\nconst text = $input.first().json.content.filter(b=>b.type==='text').map(b=>b.text).join('');\nconst match = text.replace(/```json|```/g,'').trim().match(/\\{[\\s\\S]*\\}/);\nif(!match) throw new Error('Scout: no JSON in response');\nconst r = JSON.parse(match[0]);\nreturn [{json:{...memberData, scoutResult:r, huntTrigger:r.huntTrigger===true}}];\n"
      },
      "id": "61f83970-6f8c-4623-b2eb-93d3a0fc5e08",
      "name": "Parse \u2014 Scout Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        780,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "8ae717c9-deb0-4fbf-b18e-7d9fb9459515",
              "leftValue": "={{ $json.huntTrigger }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "f7a77947-a37d-44dc-a38e-03d81cabe82a",
      "name": "HUNT \u2014 Stress Detected?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1040,
        300
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\"status\":\"literacy_complete\",\"agent\":\"Scout\",\"member\":{{ JSON.stringify($json.name) }},\"greeting\":{{ JSON.stringify($json.scoutResult.greeting) }},\"advice\":{{ JSON.stringify($json.scoutResult.advice) }},\"literacyTip\":{{ JSON.stringify($json.scoutResult.literacyTip) }},\"huntTriggered\":false,\"killSwitch\":\"*#700#\",\"dataLocation\":\"AWS Africa Cape Town\"}",
        "options": {}
      },
      "id": "7cbdc142-cc81-4c94-88c7-6816d32b38e4",
      "name": "Respond \u2014 Literacy Complete",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        1300,
        500
      ]
    },
    {
      "parameters": {
        "jsCode": "\nconst d = $input.first().json;\nconst prompt = `You are the Guardian Agent for Ujima SACCO \u2014 loan triage. Harvest-cycle-aware scoring.\nKILL SWITCH: *#733#. GUARD: No gender/ethnicity proxies. Auto-approve max KES 15,000.\nTRAIL: Transaction history (opt-in), district baselines. PII stays in Kenya.\n\nMember: ${d.name}, ${d.occupation} | Income: KES ${d.income} (${d.incomeType})\nHarvest: ${d.harvestMonths} | Children: ${d.children}\nLoan: KES ${d.loanAmount} for ${d.purpose}\nScout signal: ${d.scoutResult?.stressSignal || 'none'}\n\nSCORING (100 pts): incomeConsistency(0-40): steady=35-40, seasonal+harvest=25-35, irregular=10-24\nharvestAlignment(0-30): aligned=25-30, partial=15-24, none=0-14\ncommunitySignals(0-20): established trader=15-20, unknown=5-14\nriskDeductions(0 to -30): high loan/income ratio, many dependents, no plan\n\nDECISIONS: score>=90 AND amount<=15000=APPROVE | score<60 OR 3+flags=DENY | else=ESCALATE\nPRIDE pause: loans>50000, children<5, debt collector mention\n\nRespond ONLY valid JSON:\n{\"score\":72,\"scoreBreakdown\":{\"incomeConsistency\":28,\"harvestAlignment\":25,\"communitySignals\":14,\"riskDeductions\":-10},\"decision\":\"ESCALATE\",\"decisionReason\":\"2-sentence reason\",\"riskFlags\":[],\"memberMessage\":\"warm message with *#123# appeal right\",\"prideLoopTriggered\":false,\"prideLoopReason\":null}`;\n\nreturn [{json:{...d, requestBody: JSON.stringify({model:\"claude-sonnet-4-20250514\",max_tokens:1000,messages:[{role:\"user\",content:prompt}]})}}];\n"
      },
      "id": "50fb947d-8649-46e9-a370-6f16f9681378",
      "name": "Format \u2014 Guardian Prompt",
      "type": "n8n-nodes-base.code",
